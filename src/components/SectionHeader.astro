---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="mb-8">
  <h1 class="text-4xl md:text-5xl font-['Outfit'] font-bold text-white mb-3">{title}</h1>
  {subtitle && <p class="text-slate-dim text-lg max-w-2xl">{subtitle}</p>}
</div>
