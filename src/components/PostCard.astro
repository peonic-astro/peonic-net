---
interface Props {
  title: string;
  description: string;
  date: Date;
  href: string;
  section: string;
  thumbnail?: string;
}

const { title, description, date, href, section, thumbnail } = Astro.props;

// Section colour accents
const sectionColors: Record<string, string> = {
  astrophotography: 'text-amber',
  projects: 'text-emerald-400',
  'claudes-corner': 'text-violet-400',
  workshop: 'text-sky-400',
  'field-notes': 'text-rose-400',
};

const sectionLabels: Record<string, string> = {
  astrophotography: 'Astrophotography',
  projects: 'Projects',
  'claudes-corner': "Claude's Corner",
  workshop: 'Workshop',
  'field-notes': 'Field Notes',
};
---

<a href={href} class="group block bg-void-light rounded-lg overflow-hidden border border-white/5 hover:border-amber/30 transition-all duration-300 hover:-translate-y-1">
  {thumbnail && (
    <div class="aspect-video overflow-hidden bg-void-lighter">
      <img src={thumbnail} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
    </div>
  )}
  <div class="p-5">
    <div class="flex items-center gap-2 mb-2">
      <span class={`text-xs font-semibold uppercase tracking-wider ${sectionColors[section] || 'text-amber'}`}>
        {sectionLabels[section] || section}
      </span>
      <span class="text-slate-dim text-xs">&middot;</span>
      <time class="text-slate-dim text-xs" datetime={date.toISOString()}>
        {date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
      </time>
    </div>
    <h3 class="text-white font-semibold text-lg mb-2 group-hover:text-amber transition-colors">{title}</h3>
    <p class="text-slate-dim text-sm line-clamp-2">{description}</p>
  </div>
</a>
