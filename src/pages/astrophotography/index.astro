---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('astrophotography', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Astrophotography" description="Narrowband imaging from a Bortle 6 backyard in Suffolk, UK.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <SectionHeader
      title="Astrophotography"
      subtitle="Narrowband imaging from a Bortle 6 backyard in Suffolk, UK. Ha, OIII, SII — photon by photon."
    />

    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map(post => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            href={`/astrophotography/${post.id}`}
            section="astrophotography"
            thumbnail={post.data.thumbnail}
          />
        ))}
      </div>
    ) : (
      <p class="text-slate-dim text-lg py-20 text-center">Gallery coming soon.</p>
    )}
  </div>
</BaseLayout>
