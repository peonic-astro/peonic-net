---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('field-notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Field Notes" description="Short-form posts, random discoveries, opinions, and learning in public.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <SectionHeader
      title="Field Notes"
      subtitle="Short-form posts. Learning in public, random discoveries, opinions, rants."
    />

    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map(post => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            href={`/field-notes/${post.id}`}
            section="field-notes"
            thumbnail={post.data.thumbnail || post.data.hero_image}
          />
        ))}
      </div>
    ) : (
      <p class="text-slate-dim text-lg py-20 text-center">Field notes coming soon.</p>
    )}
  </div>
</BaseLayout>
