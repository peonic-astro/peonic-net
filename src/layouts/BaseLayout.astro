---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = 'Astrophotography, projects, and tinkering by Koz.',
  ogImage,
  ogType = 'website',
  jsonLd,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
// Fall back to a default social image if none provided
const socialImage = ogImage || new URL('/images/hero/bubble.jpg', Astro.site).toString();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title} | Peonic</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} | Peonic`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:site_name" content="Peonic" />

    <!-- Twitter/X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Peonic`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <!-- Structured data -->
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet" />

    <!-- Theme toggle: inline script prevents flash of wrong theme -->
    <script is:inline>
      const theme = localStorage.getItem('theme') || 'dark';
      if (theme === 'light') document.documentElement.classList.add('light');
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <nav class="sticky top-0 z-50 bg-void/80 backdrop-blur-md border-b border-white/5">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a href="/" class="text-xl font-bold tracking-tight text-white font-['Outfit']">
            PEONIC
          </a>

          <!-- Nav links (desktop) -->
          <div class="hidden md:flex items-center gap-6 text-sm">
            <a href="/astrophotography" class="text-slate-dim hover:text-white transition-colors">Astrophotography</a>
            <a href="/projects" class="text-slate-dim hover:text-white transition-colors">Projects</a>
            <a href="/claudes-corner" class="text-slate-dim hover:text-white transition-colors">Claude's Corner</a>
            <a href="/field-notes" class="text-slate-dim hover:text-white transition-colors">Field Notes</a>
            <button id="theme-toggle" class="p-2 text-slate-dim hover:text-amber transition-colors" aria-label="Toggle theme">
              <svg class="w-5 h-5 hidden dark-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
              <svg class="w-5 h-5 hidden light-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
              </svg>
            </button>
          </div>

          <!-- Mobile menu button -->
          <button id="mobile-menu-btn" class="md:hidden p-2 text-slate-dim" aria-label="Menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-white/5 bg-void/95 backdrop-blur-md">
        <div class="px-4 py-3 space-y-2">
          <a href="/astrophotography" class="block py-2 text-slate-dim hover:text-white">Astrophotography</a>
          <a href="/projects" class="block py-2 text-slate-dim hover:text-white">Projects</a>
          <a href="/claudes-corner" class="block py-2 text-slate-dim hover:text-white">Claude's Corner</a>
          <a href="/field-notes" class="block py-2 text-slate-dim hover:text-white">Field Notes</a>
        </div>
      </div>
    </nav>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-white/5 bg-void-light">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <h3 class="text-white font-['Outfit'] font-bold text-lg mb-3">PEONIC</h3>
            <p class="text-slate-dim text-sm">Astrophotography, AI tinkering, and assorted rabbit holes. Shot from Bortle 6 skies in Suffolk, UK.</p>
          </div>
          <div>
            <h4 class="text-white font-semibold mb-3">Sections</h4>
            <ul class="space-y-1 text-sm text-slate-dim">
              <li><a href="/astrophotography" class="hover:text-amber transition-colors">Astrophotography</a></li>
              <li><a href="/projects" class="hover:text-amber transition-colors">Projects</a></li>
              <li><a href="/claudes-corner" class="hover:text-amber transition-colors">Claude's Corner</a></li>
              <li><a href="/field-notes" class="hover:text-amber transition-colors">Field Notes</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-white font-semibold mb-3">Links</h4>
            <ul class="space-y-1 text-sm text-slate-dim">
              <li><a href="/about" class="hover:text-amber transition-colors">About</a></li>
              <li><a href="https://github.com/peonic-astro" class="hover:text-amber transition-colors">GitHub</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-8 pt-8 border-t border-white/5 text-center text-sm text-slate-dim">
          &copy; {new Date().getFullYear()} Peonic. Built with Astro, deployed on Cloudflare Pages.
        </div>
      </div>
    </footer>

    <!-- Theme toggle + mobile menu scripts -->
    <script>
      // Theme toggle
      const toggle = document.getElementById('theme-toggle');
      const darkIcon = toggle?.querySelector('.dark-icon') as HTMLElement;
      const lightIcon = toggle?.querySelector('.light-icon') as HTMLElement;

      function updateIcons() {
        const isLight = document.documentElement.classList.contains('light');
        if (darkIcon) darkIcon.style.display = isLight ? 'block' : 'none';
        if (lightIcon) lightIcon.style.display = isLight ? 'none' : 'block';
      }

      updateIcons();

      toggle?.addEventListener('click', () => {
        document.documentElement.classList.toggle('light');
        const isLight = document.documentElement.classList.contains('light');
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
        updateIcons();
      });

      // Mobile menu
      const menuBtn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      menuBtn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });

      // Lightbox with zoom and pan
      const overlay = document.getElementById('lightbox-overlay') as HTMLElement;
      const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
      const lbCaption = document.getElementById('lightbox-caption') as HTMLElement;
      const lbContainer = document.getElementById('lightbox-container') as HTMLElement;

      let scale = 1;
      let panX = 0;
      let panY = 0;
      let isDragging = false;
      let dragStartX = 0;
      let dragStartY = 0;
      let panStartX = 0;
      let panStartY = 0;

      function updateTransform() {
        lbImg.style.transform = `translate(${panX}px, ${panY}px) scale(${scale})`;
      }

      function resetZoom() {
        scale = 1;
        panX = 0;
        panY = 0;
        updateTransform();
        lbImg.style.cursor = 'zoom-in';
      }

      function closeLightbox() {
        overlay.classList.add('hidden');
        document.body.style.overflow = '';
        lbImg.src = '';
        resetZoom();
      }

      document.querySelectorAll<HTMLImageElement>('.lightbox').forEach(img => {
        img.style.cursor = 'zoom-in';
        img.addEventListener('click', () => {
          lbImg.src = img.src;
          lbCaption.textContent = img.alt || '';
          overlay.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
          resetZoom();
        });
      });

      // Mouse wheel zoom
      lbContainer?.addEventListener('wheel', (e) => {
        e.preventDefault();
        const delta = e.deltaY > 0 ? 0.8 : 1.25;
        const newScale = Math.min(Math.max(scale * delta, 1), 10);

        if (newScale === 1) {
          resetZoom();
        } else {
          // Zoom towards mouse position
          const rect = lbImg.getBoundingClientRect();
          const cx = e.clientX - rect.left - rect.width / 2;
          const cy = e.clientY - rect.top - rect.height / 2;
          const ratio = 1 - newScale / scale;
          panX += cx * ratio;
          panY += cy * ratio;
          scale = newScale;
          updateTransform();
          lbImg.style.cursor = scale > 1 ? 'grab' : 'zoom-in';
        }
      }, { passive: false });

      // Click to toggle zoom
      lbImg?.addEventListener('click', (e) => {
        if (isDragging) return;
        e.stopPropagation();
        if (scale === 1) {
          // Zoom to 3x at click position
          const rect = lbImg.getBoundingClientRect();
          const cx = e.clientX - rect.left - rect.width / 2;
          const cy = e.clientY - rect.top - rect.height / 2;
          scale = 3;
          panX = -cx * 2;
          panY = -cy * 2;
          updateTransform();
          lbImg.style.cursor = 'grab';
        } else {
          resetZoom();
        }
      });

      // Drag to pan when zoomed
      lbImg?.addEventListener('mousedown', (e) => {
        if (scale <= 1) return;
        e.preventDefault();
        isDragging = false;
        dragStartX = e.clientX;
        dragStartY = e.clientY;
        panStartX = panX;
        panStartY = panY;
        lbImg.style.cursor = 'grabbing';

        const onMove = (ev: MouseEvent) => {
          const dx = ev.clientX - dragStartX;
          const dy = ev.clientY - dragStartY;
          if (Math.abs(dx) > 3 || Math.abs(dy) > 3) isDragging = true;
          panX = panStartX + dx;
          panY = panStartY + dy;
          updateTransform();
        };

        const onUp = () => {
          document.removeEventListener('mousemove', onMove);
          document.removeEventListener('mouseup', onUp);
          lbImg.style.cursor = scale > 1 ? 'grab' : 'zoom-in';
          // Reset isDragging after click event fires
          setTimeout(() => { isDragging = false; }, 0);
        };

        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup', onUp);
      });

      // Close on overlay background click or close button
      overlay?.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target === overlay || target === lbContainer || target.id === 'lightbox-close') {
          closeLightbox();
        }
      });

      document.addEventListener('keydown', (e) => {
        if (overlay.classList.contains('hidden')) return;
        if (e.key === 'Escape') closeLightbox();
      });
    </script>

    <!-- Lightbox overlay -->
    <div id="lightbox-overlay" class="hidden fixed inset-0 z-[100] bg-black/95 flex flex-col items-center justify-center">
      <button id="lightbox-close" class="absolute top-4 right-4 text-white/70 hover:text-white text-4xl leading-none z-10">&times;</button>
      <div id="lightbox-container" class="flex-1 w-full flex items-center justify-center overflow-hidden">
        <img id="lightbox-img" src="" alt="" class="max-h-[85vh] max-w-[95vw] object-contain rounded-lg transition-transform duration-150 ease-out select-none" draggable="false" />
      </div>
      <p id="lightbox-caption" class="text-slate-dim text-sm py-3 text-center max-w-2xl"></p>
    </div>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  .prose {
    line-height: 1.8;
    font-size: 1.05rem;
  }
  .prose p {
    margin-bottom: 1.5em;
  }
  .prose h2 {
    color: #ffffff;
    font-family: 'Outfit', sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
    margin-top: 2.5em;
    margin-bottom: 1em;
  }
  .prose ul, .prose ol {
    margin-top: 1em;
    margin-bottom: 1.5em;
    padding-left: 1.5em;
  }
  .prose li {
    margin-bottom: 0.5em;
  }
  .prose figure {
    margin-top: 2em;
    margin-bottom: 2em;
  }
  .prose a {
    color: var(--color-amber);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose a:hover {
    color: var(--color-amber-light);
  }
</style>
