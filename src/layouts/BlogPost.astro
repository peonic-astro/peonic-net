---
// Generic layout for blog-style posts (Claude's Corner, Workshop, Field Notes)
interface Props {
  title: string;
  description: string;
  date: Date;
  hero_image?: string;
  tags?: string[];
  jsonLd?: Record<string, unknown>;
}

import BaseLayout from './BaseLayout.astro';

const { title, description, date, hero_image, tags = [], jsonLd } = Astro.props;
const ogImage = hero_image ? new URL(hero_image, Astro.site).toString() : undefined;
---

<BaseLayout title={title} description={description} ogImage={ogImage} ogType="article" jsonLd={jsonLd}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {hero_image && (
      <div class="rounded-xl overflow-hidden mb-8 aspect-[3/1]">
        <img src={hero_image} alt={title} class="w-full h-full object-cover" />
      </div>
    )}
    <header class="mb-8">
      <h1 class="text-4xl md:text-5xl font-['Outfit'] font-bold text-white mb-4">{title}</h1>
      <div class="flex flex-wrap items-center gap-3 text-sm text-slate-dim">
        <time datetime={date.toISOString()}>
          {date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
        </time>
        {tags.length > 0 && (
          <>
            <span>&middot;</span>
            {tags.map(tag => (
              <span class="bg-void-light rounded-full px-2 py-0.5 text-xs">{tag}</span>
            ))}
          </>
        )}
      </div>
    </header>
    <div class="prose prose-invert max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
